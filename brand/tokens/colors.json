    "muted":      { "hex": "#f3eee3", "oklch": "oklch(96% 0.008 80)", "name": "Paper Soft" },
    "muted_foreground": { "hex": "#5a544a", "oklch": "oklch(48% 0.01 60)", "name": "Ink Soft" },
    "border":     { "hex": "#dfd6c5", "oklch": "oklch(90% 0.008 80)", "name": "Hairline" },
