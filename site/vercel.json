{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.everythingagents.org" }],
      "destination": "https://everythingagents.org/$1",
      "permanent": true
    }
  ]
}
